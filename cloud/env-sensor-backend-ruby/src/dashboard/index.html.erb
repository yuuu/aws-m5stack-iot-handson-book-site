<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IoT 環境センサーダッシュボード</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22%232563eb%22%3E%3Cpath%20fill-rule%3D%22evenodd%22%20d%3D%22M5.6%204.8a2%202%200%200%201%202.2%201.2l1.1%202.1a1%201%200%200%200%20.9.6h2.4a1%201%200%200%200%20.9-.6l1.1-2.1a2%202%200%200%201%202.2-1.2h.2a2%202%200%200%201%202%202v10a2%202%200%200%201-2%202H5.8a2%202%200%200%201-2-2V6.8a2%202%200%200%201%202-2h-.2ZM9%2011a1%201%200%201%200%200%202h6a1%201%200%201%200%200-2H9Z%22%20clip-rule%3D%22evenodd%22%20%2F%3E%3C%2Fsvg%3E">
  <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
</head>

<body class="bg-gray-50 dark:bg-gray-900">
  <header>
    <nav class="bg-white border-gray-200 px-4 lg:px-6 py-2.5 dark:bg-gray-800">
      <div class="flex flex-wrap justify-between items-center container mx-auto">
        <a href="#" class="flex items-center">
          <svg class="w-8 h-8 mr-2 text-blue-600 dark:text-blue-500" aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd"
              d="M5.6 4.8a2 2 0 0 1 2.2 1.2l1.1 2.1a1 1 0 0 0 .9.6h2.4a1 1 0 0 0 .9-.6l1.1-2.1a2 2 0 0 1 2.2-1.2h.2a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5.8a2 2 0 0 1-2-2V6.8a2 2 0 0 1 2-2h-.2ZM9 11a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2H9Z"
              clip-rule="evenodd" />
          </svg>
          <span class="self-center text-xl font-semibold whitespace-nowrap dark:text-white">IoT Dashboard</span>
        </a>
        <div class="flex items-center">
          <select id="sensor-select"
            class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white pr-10">
            <% @device_ids.each do |device_id| %>
              <option value="<%= device_id %>" <%= @device_id == device_id ? 'selected' : '' %>><%= device_id %></option>
            <% end %>
          </select>
        </div>
      </div>
    </nav>
  </header>

  <main class="p-4 md:p-8">
    <div class="container mx-auto">
      <!-- Stats Boxes -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Current Time -->
        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <h5 class="mb-2 text-lg font-semibold text-gray-600 dark:text-gray-400">日時</h5>
          <p id="current-time" class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= @latest_record ? Time.at(@latest_record['timestamp'] / 1000).strftime('%Y-%m-%d %H:%M') : '-' %>
          </p>
        </div>
        <!-- Temperature -->
        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <h5 class="mb-2 text-lg font-semibold text-gray-600 dark:text-gray-400">温度</h5>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= @latest_record ? @latest_record['temperature'].to_f.round(1) : '-' %> <span class="text-xl font-medium">°C</span>
          </p>
        </div>
        <!-- Humidity -->
        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <h5 class="mb-2 text-lg font-semibold text-gray-600 dark:text-gray-400">湿度</h5>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= @latest_record ? @latest_record['humidity'].to_f.round(1) : '-' %> <span class="text-xl font-medium">%</span>
          </p>
        </div>
        <!-- Pressure -->
        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <h5 class="mb-2 text-lg font-semibold text-gray-600 dark:text-gray-400">気圧</h5>
          <p class="text-3xl font-bold text-gray-900 dark:text-white">
            <%= @latest_record ? @latest_record['pressure'].to_f.round(1) : '-' %> <span class="text-xl font-medium">hPa</span>
          </p>
        </div>
      </div>

      <!-- Charts in Tabs -->
      <div class="bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
        <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
          <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="myTab" data-tabs-toggle="#myTabContent"
            role="tablist">
            <li class="me-2" role="presentation">
              <button class="inline-block p-4 border-b-2 rounded-t-lg" id="temperature-tab"
                data-tabs-target="#temperature" type="button" role="tab" aria-controls="temperature"
                aria-selected="true">温度</button>
            </li>
            <li class="me-2" role="presentation">
              <button
                class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300"
                id="humidity-tab" data-tabs-target="#humidity" type="button" role="tab" aria-controls="humidity"
                aria-selected="false">湿度</button>
            </li>
            <li class="me-2" role="presentation">
              <button
                class="inline-block p-4 border-b-2 rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300"
                id="pressure-tab" data-tabs-target="#pressure" type="button" role="tab" aria-controls="pressure"
                aria-selected="false">気圧</button>
            </li>
          </ul>
        </div>
        <div id="myTabContent">
          <div class="p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="temperature" role="tabpanel"
            aria-labelledby="temperature-tab">
            <div class="relative h-[40vh] w-full">
              <canvas id="tempChart"></canvas>
            </div>
          </div>
          <div class="hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="humidity" role="tabpanel"
            aria-labelledby="humidity-tab">
            <div class="relative h-[40vh] w-full">
              <canvas id="humidityChart"></canvas>
            </div>
          </div>
          <div class="hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="pressure" role="tabpanel"
            aria-labelledby="pressure-tab">
            <div class="relative h-[40vh] w-full">
              <canvas id="pressureChart"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
  <script>
    // --- Sensor Selection Logic ---
    document.addEventListener("DOMContentLoaded", function () {
      const select = document.getElementById("sensor-select");

      select.addEventListener("change", function () {
        const deviceId = this.value;

        const url = new URL(window.location.href);
        url.searchParams.set("device_id", deviceId);

        window.location.href = url.toString();
      });
    });

    // --- Chart.js Sample Data and Configuration ---
    const chartLabels = [<%= @records.map { "'#{Time.at(it['timestamp'] / 1000).strftime('%H:%M')}'" }.join(', ') %>];
    const temp_data = [<%= @records.map { it['temperature'].to_f.round(1) }.join(', ') %>];
    const humidity_data = [<%= @records.map { it['humidity'].to_f.round(1) }.join(', ') %>];
    const pressure_data = [<%= @records.map { it['pressure'].to_f.round(1) }.join(', ') %>];

    const commonChartOptions = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        }
      },
      scales: {
        x: {
          grid: {
            color: 'rgba(200, 200, 200, 0.2)'
          },
          ticks: {
            color: '#9ca3af' // text-gray-400
          }
        },
        y: {
          beginAtZero: false,
          grid: {
            color: 'rgba(200, 200, 200, 0.2)'
          },
          ticks: {
            color: '#9ca3af' // text-gray-400
          }
        }
      },
      interaction: {
        intersect: false,
        mode: 'index',
      },
      elements: {
        line: {
          tension: 0.4 // Smooth lines
        }
      }
    };

    const blueColor = 'rgb(59, 130, 246)';
    const blueBgColor = 'rgba(59, 130, 246, 0.2)';

    [
      ['tempChart', '温度', '°C', temp_data],
      ['humidityChart', '湿度', '%', humidity_data],
      ['pressureChart', '気圧', 'hPa', pressure_data]
    ].forEach(([chartId, label, unit, data]) => {
      const ctx = document.getElementById(chartId).getContext('2d');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: chartLabels,
          datasets: [{
            label, data,
            borderColor: blueColor,
            backgroundColor: blueBgColor,
            fill: true,
            pointBackgroundColor: blueColor,
            pointRadius: 4,
            pointHoverRadius: 6,
          }]
        },
        options: {
          ...commonChartOptions,
          plugins: {
            ...commonChartOptions.plugins,
            tooltip: {
              callbacks: {
                label: function (context) {
                  return ` ${context.dataset.label}: ${context.parsed.y} ${unit}`;
                }
              }
            }
          }
        }
      });
    });
  </script>
</body>
</html>
